# Global SSL Configuration
SSLSessionCache shmcb:/var/run/apache2/sslcache(512000)
SSLSessionCacheTimeout 300

# Define custom log format with request duration in microseconds (%D)
LogFormat "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\" %D" combined_time

# ---------------------------------------------------------
# PORT 80 - Redirect all HTTP traffic to HTTPS
# ---------------------------------------------------------
<VirtualHost 192.168.0.6:80>
    ServerName topspeedservice.eu
    ServerAlias www.topspeedservice.eu mail.topspeedservice.eu webmail.topspeedservice.eu admin.topspeedservice.eu

    RewriteEngine On
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    ErrorLog /var/log/virtualmin/topspeedservice.eu_error_log
    CustomLog /var/log/virtualmin/topspeedservice.eu_access_log combined_time
</VirtualHost>

# ---------------------------------------------------------
# SUBDOMAINS - Isolated to prevent Proxy collision
# ---------------------------------------------------------
<VirtualHost 192.168.0.6:443>
    ServerName webmail.topspeedservice.eu
    SSLEngine on
    SSLCertificateFile /home/topspeedservice.eu/ssl.cert
    SSLCertificateKeyFile /home/topspeedservice.eu/ssl.key
    SSLCACertificateFile /home/topspeedservice.eu/ssl.ca
    Redirect permanent / https://topspeedservice.eu:20000/
</VirtualHost>

<VirtualHost 192.168.0.6:443>
    ServerName admin.topspeedservice.eu
    SSLEngine on
    SSLCertificateFile /home/topspeedservice.eu/ssl.cert
    SSLCertificateKeyFile /home/topspeedservice.eu/ssl.key
    SSLCACertificateFile /home/topspeedservice.eu/ssl.ca
    Redirect permanent / https://topspeedservice.eu:8989/
</VirtualHost>

# ---------------------------------------------------------
# MAIN NUXT APPLICATION (Port 443)
# ---------------------------------------------------------
<VirtualHost 192.168.0.6:443>
    ServerName topspeedservice.eu
    ServerAlias www.topspeedservice.eu

    # Strict Modern SSL Configuration
    SSLEngine on
    SSLProtocol TLSv1.2 TLSv1.3
    SSLCipherSuite HIGH:!aNULL:!MD5:!3DES
    SSLHonorCipherOrder On
    SSLCertificateFile /home/topspeedservice.eu/ssl.cert
    SSLCertificateKeyFile /home/topspeedservice.eu/ssl.key
    SSLCACertificateFile /home/topspeedservice.eu/ssl.ca

    # HTTP/2 Support
    Protocols h2 http/1.1

    # Security Headers & Permissions Policy
    <IfModule mod_headers.c>
        Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Header always set X-Frame-Options "SAMEORIGIN"
        Header always set X-Content-Type-Options "nosniff"
        Header always set X-XSS-Protection "1; mode=block"
        Header always set Referrer-Policy "strict-origin-when-cross-origin"
        Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    </IfModule>

    # Compression
    <IfModule mod_brotli.c>
        AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
    </IfModule>
    <IfModule mod_deflate.c>
        AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
    </IfModule>

    # Sitemap & Robots - Self-Contained Proxy & Headers
    <LocationMatch "sitemap\.xml$">
        Header unset Cache-Control
        Header unset Expires
        Header always set Cache-Control "public, max-age=3600, must-revalidate"
        Header set Content-Type "application/xml"
        ProxyPass http://localhost:3000/sitemap.xml
        ProxyPassReverse http://localhost:3000/sitemap.xml
    </LocationMatch>

    <LocationMatch "robots\.txt$">
        Header unset Cache-Control
        Header unset Expires
        Header always set Cache-Control "public, max-age=3600, must-revalidate"
        Header set Content-Type "text/plain"
        ProxyPass http://localhost:3000/robots.txt
        ProxyPassReverse http://localhost:3000/robots.txt
    </LocationMatch>

    # Global Proxy Configuration
    ProxyPreserveHost On
    ProxyRequests Off
    ProxyTimeout 30
    ProxyErrorOverride On
    RequestHeader set X-Forwarded-Proto "https"

    # 1. Catch Let's Encrypt FIRST
    ProxyPass /.well-known !

    # 2. Catch everything else
    ProxyPass / http://localhost:3000/
    ProxyPassReverse / http://localhost:3000/

    # Logging using the custom duration format
    ErrorLog /var/log/virtualmin/topspeedservice.eu_error_log
    CustomLog /var/log/virtualmin/topspeedservice.eu_access_log combined_time
</VirtualHost>

